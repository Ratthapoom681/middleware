# ──────────────────────────────────────────────
# Middleware Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ── Server ──
HOST=0.0.0.0
PORT=8000

# ── Docker Compose PostgreSQL defaults ──
POSTGRES_DB=middleware
POSTGRES_USER=middleware
POSTGRES_PASSWORD=middleware_secret

# ── Database ──
# SQLite (local development):
DATABASE_URL=sqlite:///./data/db/middleware.db
# PostgreSQL (Docker / production):
# DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# ── Logging ──
LOG_LEVEL=INFO
LOG_FILE=data/logs/middleware.log

# ── Wazuh (configured via Settings UI) ──
# WAZUH_URL=https://wazuh.example.com
# WAZUH_API_USER=admin
# WAZUH_API_PASSWORD=changeme

# ── DefectDojo (configured via Settings UI) ──
# DEFECTDOJO_URL=https://defectdojo.example.com/api/v2
# DEFECTDOJO_API_KEY=your-defectdojo-api-key

# ── Redmine (configured via Settings UI) ──
# REDMINE_URL=https://redmine.example.com
# REDMINE_API_KEY=your-redmine-api-key
# REDMINE_PROJECT_ID=security
